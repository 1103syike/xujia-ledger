rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userMemberId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.memberId;
    }

    function isMember() {
      return isSignedIn() && userMemberId() != null;
    }

    function isSelf(memberId) {
      return isMember() && userMemberId() == memberId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // 登入前需讀取自訂密碼（內部私用）
    match /memberProfiles/{memberId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSelf(memberId);
    }

    match /expenses/{expenseId} {
      allow read: if isMember();
      allow create: if isMember();
      allow update: if isMember();
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isMember();
      allow create: if isMember();
      allow update, delete: if false;
    }
  }
}
